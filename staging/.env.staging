# Staging Environment Configuration
# This file is used for testing without affecting production

# =================== DATABASE ===================
# Staging uses SQLite locally, NOT Turso production DB
# Comment out Turso credentials to use local SQLite
#TURSO_DATABASE_URL=
#TURSO_AUTH_TOKEN=
# STAGING uses local SQLite (news_queue_staging.db)
# DO NOT use production Turso credentials here

# =================== MAX BOT (DISABLED) ===================
# Staging does NOT post to MAX channel
# These are dummy values - will not be used
MAX_BOT_TOKEN=staging_dummy_token_do_not_use
MAX_CHANNEL_ID=staging_dummy_channel_do_not_use
CHANNEL_ID=staging_dummy_channel_do_not_use

# =================== LLM CONFIG ===================
# Use GitHub token for LLM if available
GITHUB_TOKEN=

# =================== EXA CONFIG (DISABLED) ===================
# Exa is disabled in staging
ENABLE_EXA=false
EXA_MODE=shadow

# =================== DIGEST CONFIG (DISABLED) ===================
ENABLE_MORNING_DIGEST=false
ENABLE_EVENING_DIGEST=false
ENABLE_AUDIO_DIGEST=false

# =================== STAGING FLAGS ===================
# Staging mode - collector will use staging DB
STAGING_MODE=true

# =================== RETENTION ===================
DROP_TTL_HOURS=48
DIGEST_TTL_DAYS=5
SENT_TTL_DAYS=30
PENDING_TTL_DAYS=7